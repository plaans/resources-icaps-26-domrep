## -------------------
## LOW-LEVEL COMMANDS
## -------------------

parse_logs logs_folder tag output="summary.json":
    ./src/parse_logs.py {{logs_folder}} {{tag}} > {{output}}

_prepare_benchmarks benchmarks_folder max_plan_length plans_subfolder_name plans_extension output_file:
    ./src/prepare_benchmarks.py {{benchmarks_folder}} {{max_plan_length}} {{plans_subfolder_name}} {{plans_extension}} > {{output_file}}

solve_all_local timeout benchmarks logs_folder="":
    #!/usr/bin/env bash
    set -euo pipefail
    cat {{benchmarks}} | while read -r domain_file problem_file plan_file; do
        if [ -z {{logs_folder}} ]; then
            just solve_one_local {{timeout}} "$plan_file" "$domain_file" "$problem_file"
        else
            domain_name=$(basename $(dirname "${domain_file}"))
            plan_name=$(basename "${plan_file%.*}")
            instance_id="${domain_name}__${plan_name}"
            output="{{logs_folder}}/aries-domrep-${instance_id}.log"
            just solve_one_local {{timeout}} "$plan_file" "$domain_file" "$problem_file" > "$output"
        fi
    done 

solve_all_slurm timeout benchmarks logs_folder:
    #!/usr/bin/env bash
    set -euo pipefail
    cat {{benchmarks}} | while read -r domain_file problem_file plan_file; do
        just solve_one_slurm {{logs_folder}} {{timeout}} "$plan_file" "$domain_file" "$problem_file"
    done 

solve_one_local timeout plan_file domain_file="" problem_file="":
    #!/usr/bin/env bash
    set -euo pipefail
    command="timeout {{timeout}} {{aries}} dom-repair --mode {{aries_repair_mode}} {{plan_file}}"

    if test "{{domain_file}}" && test "{{problem_file}}"; then
        command="${command} -p {{problem_file}} -d {{domain_file}}"
    elif test "{{problem_file}}"; then
        command="${command} -p {{problem_file}}"
    elif test "{{domain_file}}"; then
        command="${command} -d {{domain_file}}"
    else
        command="${command}" # If unspecified, Aries automatically finds the domain and problem paths
    fi

    ($command || echo "REPORT {{plan_file}}         TIMEOUT") #| grep REPORT

solve_one_slurm logs_folder timeout plan_file domain_file problem_file="":
    #!/usr/bin/env bash
    set -euo pipefail
    command="timeout {{timeout}} {{aries}} dom-repair --mode {{aries_repair_mode}} {{plan_file}} -d {{domain_file}}"

    if test "{{problem_file}}"; then
        command="$command -p {{problem_file}}"
    else
        command="$command" # If unspecified, Aries automatically finds the domain and problem paths
    fi

    domain_name=$(basename $(dirname {{domain_file}}))
    aux={{plan_file}}
    plan_name=$(basename "${aux%.*}")
    instance_id="${domain_name}__${plan_name}"

    job_name="aries-domrep-${instance_id}"
    output="{{logs_folder}}/job_%j_aries-domrep-${instance_id}.log"
    command="${command} || echo 'REPORT {{plan_file}}         TIMEOUT' "

    ./slurmshortcut.sh ${job_name} {{timeout}} "${output}" "${command}"
