#### Running experiments

## !!! NOTE: Please note that by default, the path to the logs folder hardcoded in the commands below contains the `independent` folder !!!
## !!!       Be sure to change it appropriately / suitably to your needs !!!

solve_all_local_ground:
    #!/usr/bin/env bash
    logs_folder=output/aries/ground/logs
    rm "$logs_folder/*"
    just solve_all_local 60 benchmarks_ground.txt "$logs_folder"

