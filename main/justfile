#### Log parsing

parse_logs_all: 
    just parse_logs_ground
    just parse_logs_lifted_standard_033
    just parse_logs_lifted_standard_066
    just parse_logs_lifted_standard_100
    just parse_logs_lifted_independent_033
    just parse_logs_lifted_independent_066
    just parse_logs_lifted_independent_100

parse_logs_ground:
    #!/usr/bin/env bash
    logs_folder=output/aries/ground/logs
    output_file=output/aries/ground/summary.json
    just parse_logs "$logs_folder" aries_ground "$output_file"

